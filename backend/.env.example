# Flask Configuration
# IMPORTANT: Generate a new SECRET_KEY using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-generate-new-one

# Environment (development, production, testing)
FLASK_ENV=production

# Debug Mode (MUST be False in production)
DEBUG=False

# Database Configuration
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/database_name
# For development, SQLite is used by default:
# DATABASE_URL=sqlite:///fardi.db

# Session Configuration
# For production, use Redis:
# REDIS_URL=redis://localhost:6379/0

# API Keys (Required)
GROQ_API_KEY=your-groq-api-key-here
SAPLING_API_KEY=your-sapling-api-key-here

# CORS Configuration (Optional)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Default Admin Account (created automatically on first run if no admin exists)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@fardi.local
ADMIN_PASSWORD=Admin@1234

# Server Configuration
PORT=5010
HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
